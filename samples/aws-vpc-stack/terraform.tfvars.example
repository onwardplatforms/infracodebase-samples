# Copy this file to terraform.tfvars and customize

# Required: Unique identifier for this demo
demo_id = "mytest"

# Optional: AWS region (default: us-east-1)
# aws_region = "us-east-1"

# Optional: VPC CIDR block (default: 10.60.0.0/16)
# vpc_cidr = "10.60.0.0/16"

# Optional: Create RDS instance (default: true)
# create_rds = true

# Optional: Place EC2 in public subnet (default: true)
# - true  = EC2 in public subnet, no NAT Gateway (free tier eligible)
# - false = EC2 in private subnet with NAT Gateway (~$32/mo cost)
# ec2_public_access = true
